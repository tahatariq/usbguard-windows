<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS HttpPlatformHandler configuration for the USBGuard API.

  HttpPlatformHandler starts start.cmd, which resolves Python automatically:
    - If a .venv virtual environment exists in the project root, it is used.
    - Otherwise the system Python (from PATH) is used.

  No Python path or version number is hardcoded here.
  Prerequisite: Python 3.12+ must be installed and either on the system PATH
                or in a .venv virtual environment in this directory.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler" path="*" verb="*"
           modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>

    <!--
      processPath: cmd.exe is always at %SystemRoot%\System32 on any Windows version.
      arguments:   /c start.cmd runs our wrapper script (relative to this file's directory).
      stdoutLogFile: relative path — logs go into the project's own logs\ folder.
    -->
    <httpPlatform processPath="%SystemRoot%\System32\cmd.exe"
                  arguments="/c start.cmd"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\python.log"
                  startupTimeLimit="30"
                  requestTimeout="00:05:00">
      <environmentVariables>
        <environmentVariable name="HTTP_PLATFORM_PORT" value="%HTTP_PLATFORM_PORT%" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
